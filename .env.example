# LLM Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# OCR
TESSERACT_CMD=
TEXT_DENSITY_THRESHOLD=200
OCR_CONFIDENCE_THRESHOLD=60
FIELD_CONFIDENCE_THRESHOLD=0.75

# App
DEBUG=false
LOG_LEVEL=INFO
UPLOAD_DIR=./tmp/uploads
OUTPUT_DIR=./tmp/outputs
